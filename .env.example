# ============================================
# Silicon Rider Bench - 环境配置文件
# ============================================

# --------------------------------------------
# API 配置（必需）
# --------------------------------------------
# API Key - 支持 OpenRouter、OpenAI 等兼容服务
# OpenRouter: 从 https://openrouter.ai/ 获取
# OpenAI: 从 https://platform.openai.com/ 获取
API_KEY=your_api_key_here

# --------------------------------------------
# AI 模型配置
# --------------------------------------------
# 指定要使用的 AI 模型
# 支持所有 OpenRouter 上的模型，例如：
# - anthropic/claude-3.5-sonnet (推荐，性能优秀)
# - anthropic/claude-3-opus (最强性能，成本较高)
# - anthropic/claude-3-haiku (快速，成本低)
# - openai/gpt-4-turbo (OpenAI 最新模型)
# - openai/gpt-4 (稳定可靠)
# - openai/gpt-3.5-turbo (快速，成本低)
# - google/gemini-pro (Google 模型)
MODEL_NAME=anthropic/claude-3.5-sonnet

# --------------------------------------------
# API 基础 URL
# --------------------------------------------
# OpenRouter API 端点
# 如果使用其他兼容 OpenAI SDK 的服务，可以修改此 URL
BASE_URL=https://openrouter.ai/api/v1

# --------------------------------------------
# OpenRouter 可选配置
# --------------------------------------------
# 你的网站 URL（用于 OpenRouter 排名和统计）
# 留空则不参与排名
SITE_URL=

# 你的应用名称（用于 OpenRouter 统计）
APP_NAME=Silicon Rider Bench

# --------------------------------------------
# 高级配置（可选）
# --------------------------------------------
# 最大迭代次数（AI 模型的最大对话轮数）
# 默认值：300
# Level 0.1 通常需要 5-10 次迭代
# Level 1 可能需要 100-300 次迭代
# 如果达到最大迭代次数，模拟会自动终止
MAX_ITERATIONS=300

# API 请求超时时间（毫秒）
# API_TIMEOUT=60000

# 最大重试次数
# MAX_RETRIES=3

# 是否启用调试日志（显示完整的请求和响应 JSON）
# 设置为 true 可以看到详细的 AI 请求和响应内容
# DEBUG=true
